# =====================================
# Navaxa · Variables de entorno
# =====================================
# Copia este archivo a .env y completa los valores.
# En el VPS, `docker compose` lee este `.env` (ver DEPLOY.md).

# ---- Postgres (contenedor de docker-compose) ----
# La contraseña en producción DEBE ser fuerte y secreta.
POSTGRES_USER="navaxa"
POSTGRES_PASSWORD="cambiar-por-password-fuerte"
POSTGRES_DB="navaxa"

# ---- Base de datos (DATABASE_URL) ----
# En docker-compose el servicio `web` arma DATABASE_URL desde POSTGRES_* apuntando
# al servicio `postgres`, así que esta línea es para herramientas locales/migraciones
# fuera de docker. (Local dev en Windows: puerto 55432 vía docker-compose.override.yml.)
DATABASE_URL="postgresql://navaxa:navaxa@localhost:5432/navaxa?schema=public"

# ---- Auth ----
# OBLIGATORIO en prod, mínimo 16 chars (se valida al arrancar). Genera con:
#   openssl rand -base64 32
AUTH_SECRET="cambiar-en-produccion-por-32-bytes-aleatorios-base64"
AUTH_URL="https://navaxa.cl"
NEXTAUTH_URL="https://navaxa.cl"

# ---- App ----
# Dominio real en prod. Las URLs de reservas/emails y el bundle del cliente se arman
# con esto. OJO: es build-time (docker-compose lo pasa como build arg a la imagen).
NEXT_PUBLIC_APP_URL="https://navaxa.cl"
NODE_ENV="production"

# ---- Storage (Cloudflare R2 / S3-compatible) ----
# Valores: mock | r2 | s3.  En prod usar "r2" (la lógica ya existe; solo faltan llaves).
STORAGE_PROVIDER="mock"
STORAGE_BUCKET="navaxa-uploads"
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://xxxxx.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL="https://cdn.navaxa.cl"

# ---- Notificaciones ----
# Email: mock | resend.  En prod usar "resend" (proveedor ya implementado).
NOTIF_EMAIL_PROVIDER="mock"
RESEND_API_KEY=""

# WhatsApp: mock | meta.  Feature de plan PRO/ENTERPRISE.
# Meta Cloud API: manda por template Utility aprobado (ver docs/whatsapp-templates.md).
NOTIF_WHATSAPP_PROVIDER="mock"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_TEMPLATE_LANG="es"
# App Secret de la app de Meta: verifica la firma X-Hub-Signature-256 del webhook
# entrante. Sin esto el webhook POST rechaza todo (fail-closed).
WHATSAPP_APP_SECRET=""

# ---- Pagos ----
# Abono de reserva (lib/payments.ts) y suscripción SaaS (lib/billing.ts).
# "mock" = checkout simulado en /pagar/[token]; "webpay" = Webpay Plus real.
PAYMENT_PROVIDER="mock"

# Webpay Plus (Transbank). Con WEBPAY_ENV="production" hay que poner las
# credenciales propias: en prod el código falla al arrancar si detecta las
# públicas de integración (si no, se cobraría con tarjetas de prueba).
WEBPAY_ENV="integration"
WEBPAY_COMMERCE_CODE=""
WEBPAY_API_KEY=""
# Escotilla SOLO para el stack de prueba (docker-compose.sandbox.yml): permite
# modo integración con NODE_ENV=production. NUNCA en el .env de producción.
WEBPAY_ALLOW_INTEGRATION=""

# Webpay Oneclick: renovación automática de la suscripción SaaS. El dueño
# inscribe su tarjeta una vez y el cron cobra sin él (lib/subscription-billing.ts).
# Oneclick es siempre "Mall": código de comercio padre (autentica) + hijo (recibe
# el cobro). Se afilian aparte de Webpay Plus, en el portal de Transbank.
# Vacíos = credenciales públicas de integración (solo sirven con WEBPAY_ENV distinto
# de "production"; en prod el arranque falla).
ONECLICK_MALL_COMMERCE_CODE=""
ONECLICK_CHILD_COMMERCE_CODE=""
ONECLICK_API_KEY=""

# ---- Captcha (Cloudflare Turnstile) ----
# Protege la reserva pública contra bots. Las dos llaves salen del dashboard de
# Cloudflare → Turnstile → Add site (el dominio debe incluir navaxa.cl).
# Si falta cualquiera de las dos, el captcha queda apagado (el widget no aparece
# y el servidor no verifica). Se leen en runtime: basta reiniciar el contenedor,
# NO hace falta rebuild (la site key viaja como prop desde el server).
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---- IA ----
ANTHROPIC_API_KEY=""
AI_MODEL="claude-haiku-4-5"

# ---- Cron ----
# OBLIGATORIO para el webhook de jobs (fail-closed si falta). En VPS de instancia
# única, docker-compose ya setea INTERNAL_CRON=true (corre los jobs sin cron externo).
CRON_SECRET="cambiar-por-token-largo-aleatorio"

# ---- Solo dev, opcional ----
# Si tu red corporativa intercepta TLS y next/font no puede bajar fuentes, descomenta:
# NODE_TLS_REJECT_UNAUTHORIZED="0"

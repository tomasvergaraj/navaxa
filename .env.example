# =====================================
# Navaxa · Variables de entorno
# =====================================
# Copia este archivo a .env y completa los valores.
# En el VPS, `docker compose` lee este `.env` (ver DEPLOY.md).

# ---- Postgres (contenedor de docker-compose) ----
# La contraseña en producción DEBE ser fuerte y secreta.
POSTGRES_USER="navaxa"
POSTGRES_PASSWORD="cambiar-por-password-fuerte"
POSTGRES_DB="navaxa"

# ---- Base de datos (DATABASE_URL) ----
# En docker-compose el servicio `web` arma DATABASE_URL desde POSTGRES_* apuntando
# al servicio `postgres`, así que esta línea es para herramientas locales/migraciones
# fuera de docker. (Local dev en Windows: puerto 55432 vía docker-compose.override.yml.)
DATABASE_URL="postgresql://navaxa:navaxa@localhost:5432/navaxa?schema=public"

# ---- Auth ----
# OBLIGATORIO en prod, mínimo 16 chars (se valida al arrancar). Genera con:
#   openssl rand -base64 32
AUTH_SECRET="cambiar-en-produccion-por-32-bytes-aleatorios-base64"
AUTH_URL="https://navaxa.cl"
NEXTAUTH_URL="https://navaxa.cl"

# ---- App ----
# Dominio real en prod. Las URLs de reservas/emails y el bundle del cliente se arman
# con esto. OJO: es build-time (docker-compose lo pasa como build arg a la imagen).
NEXT_PUBLIC_APP_URL="https://navaxa.cl"
NODE_ENV="production"

# ---- Storage (Cloudflare R2 / S3-compatible) ----
# Valores: mock | r2 | s3.  En prod usar "r2" (la lógica ya existe; solo faltan llaves).
STORAGE_PROVIDER="mock"
STORAGE_BUCKET="navaxa-uploads"
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://xxxxx.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL="https://cdn.navaxa.cl"

# ---- Notificaciones ----
# Email: mock | resend.  En prod usar "resend" (proveedor ya implementado).
NOTIF_EMAIL_PROVIDER="mock"
RESEND_API_KEY=""

# WhatsApp: mock | meta.  Feature de plan PRO/ENTERPRISE.
# Meta Cloud API: manda por template Utility aprobado (ver docs/whatsapp-templates.md).
NOTIF_WHATSAPP_PROVIDER="mock"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_TEMPLATE_LANG="es"

# ---- Pagos ----
# Abono de reserva (lib/payments.ts) y suscripción SaaS (lib/billing.ts).
# Hoy solo existe el proveedor "mock"; la pasarela real (Flow/Webpay/Mercado Pago)
# se enchufa por la abstracción ya existente. Cambiar cuando esté implementada.
PAYMENT_PROVIDER="mock"

# ---- IA ----
ANTHROPIC_API_KEY=""
AI_MODEL="claude-haiku-4-5"

# ---- Cron ----
# OBLIGATORIO para el webhook de jobs (fail-closed si falta). En VPS de instancia
# única, docker-compose ya setea INTERNAL_CRON=true (corre los jobs sin cron externo).
CRON_SECRET="cambiar-por-token-largo-aleatorio"

# ---- Solo dev, opcional ----
# Si tu red corporativa intercepta TLS y next/font no puede bajar fuentes, descomenta:
# NODE_TLS_REJECT_UNAUTHORIZED="0"

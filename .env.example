# =====================================
# Navaxa · Variables de entorno
# =====================================
# Copia este archivo a .env y completa los valores.

# ---- Base de datos ----
DATABASE_URL="postgresql://navaxa:navaxa@localhost:5432/navaxa?schema=public"

# ---- Auth ----
# Genera con: openssl rand -base64 32
AUTH_SECRET="cambiar-en-produccion-por-32-bytes-aleatorios-base64"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ---- Storage (Cloudflare R2 / S3-compatible) ----
# Valores: mock | r2 | s3
STORAGE_PROVIDER="mock"
STORAGE_BUCKET="navaxa-uploads"
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://xxxxx.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL="https://cdn.navaxa.app"

# ---- Notificaciones ----
# Email: mock | resend
NOTIF_EMAIL_PROVIDER="mock"
RESEND_API_KEY=""

# WhatsApp: mock | twilio | meta
NOTIF_WHATSAPP_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ---- IA ----
ANTHROPIC_API_KEY=""
AI_MODEL="claude-sonnet-4-5-20250929"

# ---- App ----
# En producción: dominio real (https://navaxa.cl). Las URLs de reservas/emails se arman con esto.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ---- Cron (opcional, para jobs internos) ----
# En VPS de instancia única: INTERNAL_CRON=true para correr los jobs sin cron externo.
CRON_SECRET="cambiar-por-token-largo-aleatorio"

# ---- Solo dev, opcional ----
# Si tu red corporativa intercepta TLS y next/font no puede bajar fuentes, descomenta:
# NODE_TLS_REJECT_UNAUTHORIZED="0"

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/webhooks/notifications?job=reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/webhooks/notifications?job=recalls",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/webhooks/notifications?job=expire_payments",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/webhooks/notifications?job=renew_subscriptions",
      "schedule": "0 3 * * *"
    }
  ]
}

{
  "name": "navaxa",
  "version": "0.1.0",
  "private": true,
  "description": "El sistema operativo para barberías que recuerdan a cada cliente",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @navaxa/db prisma generate",
    "db:migrate": "pnpm --filter @navaxa/db prisma migrate dev",
    "db:deploy": "pnpm --filter @navaxa/db prisma migrate deploy",
    "db:reset": "pnpm --filter @navaxa/db prisma migrate reset",
    "db:seed": "pnpm --filter @navaxa/db exec tsx prisma/seed.ts",
    "db:studio": "pnpm --filter @navaxa/db prisma studio"
  },
  "devDependencies": {
    "turbo": "2.0.14",
    "typescript": "5.5.4",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}

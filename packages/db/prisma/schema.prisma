// =====================================
// navaxa — Prisma schema
// =====================================

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// Tenancy & Identity
// =====================

model Tenant {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  plan        Plan      @default(FREE)
  rut         String?
  phone       String?
  email       String?
  address     String?
  city        String?
  timezone    String    @default("America/Santiago")
  currency    String    @default("CLP")
  locale      String    @default("es-CL")
  logoUrl     String?
  // Key del objeto en storage (R2/S3) detrás de logoUrl/coverUrl: sin ella no se
  // puede borrar el archivo al reemplazarlo o quitarlo. Las filas previas a la
  // columna la derivan de la URL (ver storageKeyFromUrl en lib/storage.ts).
  logoKey     String?
  coverUrl    String?
  coverKey    String?
  description String?
  instagram   String?
  website     String?
  active      Boolean   @default(true)
  bookingEnabled   Boolean @default(true)
  bookingNoticeMin Int     @default(0) // anticipación mínima (min) para reservar online
  // Cobro de abono al reservar online.
  paymentsEnabled  Boolean     @default(false)
  depositType      DepositType @default(NONE)
  depositValue     Int         @default(0) // CLP si FIXED; porcentaje 0-100 si PERCENT
  // Reseñas de Google: Place ID configurado por el tenant + cache diario
  // de rating/reseñas vía Places API (ver lib/google-reviews.ts).
  googlePlaceId     String?
  googlePlaceName   String?
  googleRating      Float?
  googleReviewCount Int?
  googleReviews     Json?
  googleMapsUri     String?
  googleSyncedAt    DateTime?
  // Analítica del sitio público (plan PRO+): IDs que el tenant pega en
  // Configuración; el storefront inyecta gtag/pixel solo si el plan lo permite.
  gaMeasurementId String? // Google Analytics 4, formato G-XXXXXXXXXX
  metaPixelId     String? // Meta Pixel, numérico
  // Personalización del sitio público (plan PRO+).
  brandColor        String? // color de marca en hex (#RRGGBB) para los CTA del storefront
  brandAccentColor  String? // color de acento en hex (#RRGGBB) para realces del storefront
  marketplaceVisible Boolean @default(true) // listarse en el índice público /reservar
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users         User[]
  clients       Client[]
  services      Service[]
  appointments  Appointment[]
  barbers       Barber[]
  notifications NotificationLog[]
  campaigns     Campaign[]
  haircuts      HaircutRecord[]
  commissions   Commission[]
  payments      Payment[]
  reviews       Review[]
  products      Product[]
  sales         Sale[]
  giftCards     GiftCard[]
  giftCardOrders GiftCardOrder[]
  appointmentCharges AppointmentCharge[]
  subscription  Subscription?

  @@map("tenants")
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// Estado de facturación de la barbería (suscripción al SaaS).
model Subscription {
  id                String             @id @default(cuid())
  tenantId          String             @unique
  plan              Plan               @default(FREE)
  status            SubscriptionStatus @default(TRIALING)
  currentPeriodEnd  DateTime?          // fin del período pagado / de prueba
  cancelAtPeriodEnd Boolean            @default(false)
  billingInterval   BillingInterval    @default(MONTHLY) // mensual o anual
  provider          String             @default("mock")
  providerRef       String?
  lastPaymentAt     DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIALING  // en período de prueba
  ACTIVE    // plan pagado y vigente
  PAST_DUE  // venció y no se pudo cobrar
  CANCELED  // cancelada (volvió a FREE)
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

// Cómo se calcula el abono que paga el cliente al reservar online.
enum DepositType {
  NONE    // sin cobro
  FIXED   // monto fijo en CLP (depositValue)
  PERCENT // porcentaje del total (depositValue %); 100 = pago total
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String?
  name          String
  avatarUrl     String?
  role          Role      @default(STAFF)
  active        Boolean   @default(true)
  // Operador de la plataforma navaxa (fuera del scope tenant): da acceso a /admin.
  // Se promueve por SUPER_ADMIN_EMAILS al login, no se setea desde UI.
  platformAdmin Boolean   @default(false)
  // Corte de revocación de sesiones JWT: todo token emitido antes de esta marca
  // deja de valer (se bumpea al cambiar clave/rol o desactivar la cuenta).
  // Ver apps/web/lib/session-revocation.ts.
  sessionInvalidBefore DateTime?
  lastLoginAt   DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barber   Barber?
  sessions Session[]
  passwordTokens PasswordToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// Token de un solo uso para invitación de barberos (definir clave) y
// recuperación de contraseña. Se guarda solo el hash del token, nunca el valor en claro.
model PasswordToken {
  id        String               @id @default(cuid())
  userId    String
  tokenHash String               @unique
  purpose   PasswordTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_tokens")
}

enum PasswordTokenPurpose {
  INVITE
  RESET
}

enum Role {
  OWNER
  ADMIN
  BARBER
  STAFF
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("sessions")
}

// =====================
// Catalog
// =====================

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  price       Int      // CLP entero, sin decimales
  durationMin Int
  category    String?
  color       String?  // hex para la agenda
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments AppointmentService[]
  saleItems    SaleItem[]

  @@index([tenantId])
  @@map("services")
}

// =====================
// Barbers
// =====================

model Barber {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String   @unique
  bio            String?
  avatarUrl      String?
  avatarKey      String? // key en storage; ver Tenant.logoKey
  commissionRate Float    @default(0.4)
  specialties    String[]
  instagram      String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule     BarberSchedule[]
  timeOff      BarberTimeOff[]
  appointments Appointment[]
  commissions  Commission[]
  haircuts     HaircutRecord[]
  reviews      Review[]
  sales        Sale[]

  @@index([tenantId])
  @@map("barbers")
}

model BarberSchedule {
  id       String @id @default(cuid())
  barberId String
  weekday  Int    // 0=domingo, 6=sábado
  startMin Int    // minutos desde 00:00
  endMin   Int

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, weekday, startMin])
  @@map("barber_schedules")
}

model BarberTimeOff {
  id       String   @id @default(cuid())
  barberId String
  startsAt DateTime
  endsAt   DateTime
  reason   String?

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startsAt])
  @@map("barber_time_off")
}

// =====================
// Clients & Visual CRM
// =====================

model Client {
  id          String    @id @default(cuid())
  tenantId    String
  firstName   String
  lastName    String?
  phone       String?
  email       String?
  birthDate   DateTime?
  rut         String?
  notes       String?
  tags        String[]
  avatarUrl   String?
  lastVisitAt DateTime?
  totalVisits Int       @default(0)
  totalSpent  Int       @default(0)
  source      String?   // walkin, web, referral, instagram
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  haircuts        HaircutRecord[]
  appointments    Appointment[]
  preferences     ClientPreference?
  recommendations AIRecommendation[]
  reviews         Review[]
  sales           Sale[]

  @@index([tenantId, phone])
  @@index([tenantId, lastVisitAt])
  @@map("clients")
}

model ClientPreference {
  id                String   @id @default(cuid())
  clientId          String   @unique
  preferredBarberId String?
  hairType          String?  // straight | wavy | curly | coily
  preferredStyle    String?
  fadeType          String?  // low | mid | high | skin | taper | none
  topLength         String?  // short | medium | long
  beardStyle        String?
  allergies         String?
  notes             String?
  updatedAt         DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_preferences")
}

model HaircutRecord {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String
  barberId      String?
  appointmentId String?  @unique
  imageUrl      String
  imageKey      String? // key en storage; ver Tenant.logoKey
  thumbnailUrl  String?
  thumbnailKey  String?
  notes         String?
  rating        Int?      // 1-5; lo deja el cliente vía link público (/foto/[token])
  ratedAt       DateTime? // cuándo el cliente envió el rating
  style         String?
  performedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barber Barber? @relation(fields: [barberId], references: [id], onDelete: SetNull)

  @@index([clientId, performedAt])
  @@index([tenantId])
  @@map("haircut_records")
}

// =====================
// Appointments / Booking
// =====================

model Appointment {
  id           String            @id @default(cuid())
  tenantId     String
  clientId     String
  barberId     String
  startsAt     DateTime
  endsAt       DateTime
  status       AppointmentStatus @default(SCHEDULED)
  totalPrice   Int
  source       String?
  notes        String?
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  barber     Barber               @relation(fields: [barberId], references: [id], onDelete: Restrict)
  services   AppointmentService[]
  commission Commission?
  payment    Payment?
  review     Review?
  sales      Sale[]
  charges    AppointmentCharge[]

  @@index([tenantId, startsAt])
  @@index([barberId, startsAt])
  @@index([clientId])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING_PAYMENT // reservada pero esperando el pago del abono
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

// Abono que paga el cliente al reservar online. Una cita tiene a lo sumo un pago.
model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  appointmentId String        @unique
  amount        Int           // CLP entero: abono total, incluida la parte pagada con giftcard
  currency      String        @default("CLP")
  status        PaymentStatus @default(PENDING)
  provider      String        @default("mock")
  providerRef   String?       // id de la transacción en la pasarela
  expiresAt     DateTime      // si no se paga antes, la cita se libera
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  /// Parte del abono cubierta con saldo de giftcard. Lo que va a la pasarela es
  /// `amount - giftCardAmount`; el ingreso de esa parte ya se reconoció al emitir
  /// la giftcard, por eso se registra aparte y no se suma como cobro nuevo.
  giftCardAmount Int     @default(0)
  giftCardId     String?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  giftCard    GiftCard?   @relation(fields: [giftCardId], references: [id])
  redemptions GiftCardRedemption[]

  @@index([tenantId, status])
  @@index([status, expiresAt])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

/// Cobro online del saldo pendiente de una cita: el dueño genera un link/QR y el
/// cliente paga desde su propio teléfono.
///
/// Por qué un modelo aparte de `Payment`: ese cuelga de la cita con
/// `appointmentId @unique` (el abono de la reserva) y una cita puede necesitar
/// varios cobros del saldo. Mismo motivo por el que existe `GiftCardOrder`.
///
/// Al confirmarse crea una `Sale` con `kind: APPOINTMENT_BALANCE` — cobranza, no
/// ingreso nuevo: ese ya se reconoció con el `totalPrice` de la cita completada.
model AppointmentCharge {
  id            String        @id @default(cuid())
  tenantId      String
  appointmentId String
  amount        Int // CLP entero
  currency      String        @default("CLP")
  status        PaymentStatus @default(PENDING)
  provider      String        @default("mock")
  providerRef   String? // token_ws de Webpay
  expiresAt     DateTime // vence el enlace, no la deuda: la cita no se libera
  paidAt        DateTime?
  saleId        String?       @unique // la venta creada al confirmar el cobro
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sale        Sale?       @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([appointmentId, status])
  @@index([providerRef])
  @@index([status, expiresAt])
  @@map("appointment_charges")
}

model AppointmentService {
  id            String @id @default(cuid())
  appointmentId String
  serviceId     String
  priceCharged  Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([appointmentId, serviceId])
  @@map("appointment_services")
}

// =====================
// Commissions
// =====================

model Commission {
  id            String    @id @default(cuid())
  tenantId      String
  barberId      String
  appointmentId String    @unique
  baseAmount    Int
  rate          Float
  amount        Int
  paid          Boolean   @default(false)
  paidAt        DateTime?
  paymentMethod String?   // CASH | TRANSFER | OTHER (al liquidar)
  periodStart   DateTime
  periodEnd     DateTime
  createdAt     DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barber      Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, periodStart])
  @@index([barberId, paid])
  @@map("commissions")
}

// Reseña del cliente tras una cita completada. Una nota (1-5) por cita que
// cuenta tanto para el promedio de la barbería como para el del barbero.
model Review {
  id            String   @id @default(cuid())
  tenantId      String
  appointmentId String   @unique
  clientId      String
  barberId      String
  rating        Int // 1-5
  comment       String?
  hidden        Boolean  @default(false) // el dueño puede ocultarla del storefront
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barber      Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([tenantId, hidden, createdAt])
  @@index([barberId, hidden])
  @@map("reviews")
}

// =====================
// Notifications & Marketing
// =====================

model NotificationLog {
  id           String              @id @default(cuid())
  tenantId     String
  channel      NotificationChannel
  recipient    String
  templateKey  String
  payload      Json
  status       NotificationStatus  @default(PENDING)
  providerId   String?
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
  // Cupo mensual de WhatsApp: count por tenant+canal+mes en cada envío (hot path).
  @@index([tenantId, channel, createdAt])
  @@map("notification_logs")
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

model Campaign {
  id          String              @id @default(cuid())
  tenantId    String
  name        String
  description String?
  trigger     CampaignTrigger
  channel     NotificationChannel
  templateKey String
  active      Boolean             @default(true)
  conditions  Json
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, active])
  @@map("campaigns")
}

enum CampaignTrigger {
  POST_VISIT
  RECALL_INACTIVE
  BIRTHDAY
  APPOINTMENT_REMINDER
  MANUAL
}

// =====================
// AI Recommendations
// =====================

model AIRecommendation {
  id             String    @id @default(cuid())
  tenantId       String
  clientId       String
  generatedAt    DateTime  @default(now())
  modelVersion   String
  inputSummary   Json
  recommendation Json
  feedback       String?   // accepted | rejected | modified
  feedbackAt     DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, generatedAt])
  @@map("ai_recommendations")
}

// =====================
// Products, inventory & cash register (plan STARTER+)
// =====================

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  price     Int      // CLP entero (precio de venta)
  cost      Int?     // costo de compra, para margen en reportes
  stock     Int      @default(0)
  minStock  Int      @default(0) // umbral de alerta de reposición
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements StockMovement[]
  saleItems SaleItem[]

  @@index([tenantId, active])
  @@map("products")
}

/// Historial de stock: cada entrada/venta/ajuste queda registrada; `stock` en
/// Product es el saldo materializado (se actualiza en la misma transacción).
model StockMovement {
  id        String              @id @default(cuid())
  tenantId  String
  productId String
  delta     Int // + entrada, - venta/merma
  reason    StockMovementReason
  saleId    String?
  note      String?
  createdAt DateTime            @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId, createdAt])
  @@map("stock_movements")
}

enum StockMovementReason {
  PURCHASE // entrada de mercadería
  SALE
  ADJUSTMENT // corrección manual / merma
  RETURN // devolución (venta anulada)
}

/// Venta de caja: productos y/o servicios sueltos, opcionalmente ligada a una
/// cita (venta adicional al completar) o a un cliente registrado.
model Sale {
  id            String            @id @default(cuid())
  tenantId      String
  clientId      String?
  appointmentId String?
  barberId      String? // quién vendió (comisión de productos, futuro)
  total         Int
  paymentMethod SalePaymentMethod
  /// Parte del total pagada con saldo de giftcard. El resto (total -
  /// giftCardAmount) se pagó con `paymentMethod`; si cubre todo, el método es
  /// GIFTCARD. Se separa porque ese dinero YA entró al emitir la giftcard: los
  /// totales de caja e ingresos suman `total - giftCardAmount` para no contarlo
  /// dos veces.
  giftCardAmount Int              @default(0)
  giftCardId     String?
  /// Discrimina el ingreso nuevo de la mera cobranza. Ver enum SaleKind.
  kind          SaleKind          @default(COUNTER)
  note          String?
  cancelledAt   DateTime?
  createdAt     DateTime          @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  barber      Barber?      @relation(fields: [barberId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  giftCard    GiftCard?    @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  items       SaleItem[]
  giftCardRedemptions GiftCardRedemption[]
  appointmentCharge   AppointmentCharge?

  @@index([tenantId, createdAt])
  @@index([tenantId, appointmentId])
  @@map("sales")
}

enum SalePaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
  GIFTCARD
}

/// COUNTER: venta de mostrador (productos / servicios sueltos / giftcard
/// comprada). Es ingreso nuevo y suma en «Ventas caja».
///
/// APPOINTMENT_BALANCE: cobro del saldo pendiente de una cita. NO es ingreso
/// nuevo — ese ingreso ya se reconoció con el `totalPrice` de la cita completada
/// («Ingresos servicios»). Se excluye de «Ventas caja» para no contar dos veces,
/// y se reporta en su propia línea.
enum SaleKind {
  COUNTER
  APPOINTMENT_BALANCE
}

/// Línea de venta con snapshot de nombre y precio (histórico estable aunque el
/// producto/servicio cambie o se borre después).
model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String?
  serviceId String?
  name      String
  unitPrice Int
  qty       Int

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@map("sale_items")
}

// =====================
// Gift cards (plan PRO+)
// =====================

model GiftCard {
  id             String         @id @default(cuid())
  tenantId       String
  code           String // corto y legible, único por tenant (ej. NVX-8F3K2A)
  initialValue   Int
  balance        Int
  status         GiftCardStatus @default(ACTIVE)
  buyerName      String?
  recipientName  String?
  recipientEmail String?
  message        String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions GiftCardRedemption[]
  sales       Sale[]
  payments    Payment[]
  order       GiftCardOrder?

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("gift_cards")
}

/// Compra pública de giftcard (la vitrina, sin sesión): la giftcard NO existe
/// hasta que la pasarela confirma el cobro. Modelo aparte de `Payment` porque
/// ese exige `appointmentId` — acá no hay cita.
///
/// Al confirmar se emite la GiftCard y se registra una Sale por el monto: el
/// ingreso se reconoce al EMITIR, igual que una giftcard vendida en mostrador.
/// Cuando después se canja, la venta suma `total - giftCardAmount` y no se
/// cuenta dos veces.
model GiftCardOrder {
  id             String        @id @default(cuid())
  tenantId       String
  amount         Int // CLP entero
  currency       String        @default("CLP")
  status         PaymentStatus @default(PENDING)
  provider       String        @default("mock")
  providerRef    String? // token_ws de Webpay
  buyerName      String
  buyerEmail     String
  recipientName  String?
  recipientEmail String?
  message        String?
  expiresInMonths Int          @default(12) // vigencia de la giftcard a emitir (0 = sin vencimiento)
  expiresAt      DateTime // vence el checkout, no la giftcard
  paidAt         DateTime?
  giftCardId     String?       @unique // se llena al confirmar el cobro
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  giftCard GiftCard? @relation(fields: [giftCardId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([providerRef])
  @@map("gift_card_orders")
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED // saldo en 0
  EXPIRED
  CANCELLED
}

/// Cada consumo de saldo de una giftcard (canje parcial o total). El monto es
/// negativo cuando se devuelve saldo (venta de caja anulada): el histórico
/// queda completo y la suma de `amount` sigue siendo el consumo neto.
model GiftCardRedemption {
  id         String   @id @default(cuid())
  tenantId   String
  giftCardId String
  saleId     String? // venta de caja que consumió el saldo, si vino de ahí
  paymentId  String? // abono de reserva que consumió el saldo, si vino de ahí
  amount     Int
  note       String?
  createdAt  DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  sale     Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([giftCardId, createdAt])
  @@map("gift_card_redemptions")
}

// =====================
// Plataforma (super admin)
// =====================

/// Rastro de auditoría de las acciones del panel /admin, que operan cross-tenant
/// y fuera de scopedDb(). Sin FK a User a propósito: el registro debe sobrevivir
/// al borrado de la cuenta que lo generó, por eso se copia el email del actor.
model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorEmail  String
  action      String // p. ej. "tenant.update"
  targetType  String // p. ej. "Tenant"
  targetId    String
  before      Json? // estado previo, solo los campos tocados
  after       Json? // estado pedido, solo los campos tocados
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("admin_audit_logs")
}
